# Academic Productivity Analysis (Hypothesis Testing)
This project analyzes how study habits and lifestyle factors affect academic productivity over time.

import pandas as pd
import matplotlib.pyplot as plt
from scipy.stats import pearsonr
df = pd.read_csv('../data/student_productivity.csv')
df.head()
df.info()
df.describe()
plt.plot(df['Week'], df['Productivity'])
plt.xlabel('Week')
plt.ylabel('Productivity')
plt.title('Productivity Over Time')
plt.show()
plt.scatter(df['StudyHours'], df['Productivity'])
plt.xlabel('Study Hours')
plt.ylabel('Productivity')
plt.title('Study Hours vs Productivity')
plt.show()
plt.scatter(df['SleepAvg'], df['Productivity'])
plt.xlabel('Sleep Hours')
plt.ylabel('Productivity')
plt.title('Sleep vs Productivity')
plt.show()
plt.scatter(df['Stress'], df['Productivity'])
plt.xlabel('Stress Level')
plt.ylabel('Productivity')
plt.title('Stress vs Productivity')
plt.show()
df.corr(numeric_only=True)
